#!/usr/bin/env bash

usage() {
	cat <<-EOF
		Logs commands to a sqlite3 database for later study.

		Usage: $(basename "${0}") [-h|v|l] | ([-d[=]DATABASE] [-a|r] <COMMAND>)

		Options:
		  -h, --help                Show this help message and exit.
		  -v, --version             Show version information and exit.
		  -d, --database <DATABASE> Use the database located at DATABASE, creating it if necessary. Defaults to '\$HOME/.cmd-log.db' if unspecified.
		  -a, --add-filter          Add a filter that prevents logging commands that start with <COMMAND>. (Case sensitive)
		  -r, --remove-filter       Remove an existing filter for <COMMAND>. (Case sensitive)
		  -l, --list-filters        List existing filters and exit.
	EOF
}

version() {
	cat <<-EOF
		$(basename "${0}") 0.1.0
		Copyright © 2026 Josh Beale <jbeale2023@gmail.com>.
		Licence: The MIT License.
	EOF
}

function setup_user_db() {
	local db
	db="${1}"
  	srcdir=$(CDPATH="" cd -- "$(dirname -- "${0}")" && pwd -P)
	if ! [[ -d ${srcdir} ]]; then
		printf "%s: failed to setup user database at path '%s'.\n" "$(basename "${0}")" "${db}" >&2
		return 5
	fi
	sqlite3 "${db}" <"${srcdir}/src/setup.sql"
	sqlite3 "${db}" <<-EOF
		.parameter set :user "'${USER}'"
		.parameter set :host "'${HOSTNAME}'"
		INSERT OR IGNORE INTO users (user_name, host_name)
		VALUES (:user, :host);
	EOF
	printf "%s: setup user database at path '%s'.\n" "$(basename "${0}")" "${db}"
}

function log_command() {
	local db
	local command
	local timestamp
	local id
	db="${1}"
	printf -v command -- "%s" "${2}"
	printf -v timestamp "%(%Y-%m-%d %H:%M:%S)T" -1
	id=$(uuidgen)
	if ! [[ -f "${db}" ]]; then
		setup_user_db "${db}" || return "${?}"
	fi
	sqlite3 "${db}" <<-EOF
		.parameter set :id "'${id}'"
		.parameter set :user "'${USER}'"
		.parameter set :host "'${HOSTNAME}'"
		.parameter set :timestamp "'${timestamp}'"
		.parameter set :command "'${command}'"
		INSERT INTO command_log (id, user_name, host_name, datetime, command)
		SELECT :id, :user, :host, :timestamp, :command
		WHERE :command NOT LIKE (SELECT ignore_commands FROM configuration) || '%';
	EOF
}

function add_filter() {
	local db
	local filter
	db="${1}"
	filter="${2}"
	if ! [[ -f "${db}" ]]; then
		setup_user_db "${db}" || return "${?}"
	fi
	if ! sqlite3 "${db}" <<-EOF 2>/dev/null; then
		.parameter set :filter "'${filter}'"
		INSERT INTO configuration (ignore_commands)
		VALUES (:filter);
	EOF
		printf "%s: failed to add filter '%s'.\n" "$(basename "${0}")" "${filter}" >&2
		return 4
	fi
	printf "%s: successfully added filter '%s'.\n" "$(basename "${0}")" "${filter}"
}

function remove_filter() {
	local db
	local filter
	db="${1}"
	filter="${2}"
	if ! [[ -f "${db}" ]]; then
		setup_user_db "${db}" || return "${?}"
	fi
	rows=$(sqlite3 "${db}" <<-EOF 2>/dev/null
		.parameter set :filter "'${filter}'"
		DELETE FROM configuration WHERE ignore_commands = :filter;
		SELECT changes();
		EOF
	)
	if (( rows != 1 )); then
		printf "%s: failed to remove filter '%s'.\n" "$(basename "${0}")" "${filter}" >&2
		return 4
	fi
	printf "%s: successfully removed filter '%s'.\n" "$(basename "${0}")" "${filter}"
}

function list_filters() {
	local db
	db="${1}"
	if ! [[ -f "${db}" ]]; then
		setup_user_db "${db}" || return "${?}"
	fi
	printf "Current Filters\n"
	sqlite3 -column "${db}" "SELECT * FROM configuration;"
}

function main() {
	if ! sqlite3 --version &>/dev/null; then
		printf "%s: sqlite3 is required. Please install it and try again.\n" "$(basename "${0}")" >&2
		return 3
	fi
	if ! uuidgen --version &>/dev/null; then
		printf "%s: uuidgen is required. Please install it and try again.\n" "$(basename "${0}")" >&2
		return 3
	fi
	local db
	local command
	local adding_filter
	local removing_filter
	local listing_filters
	while [[ "${#}" -gt 0 ]]; do
		if printf "%s\n" "${1}" | grep -qE -- "^(-h)|(--h(e(l(p)?)?)?)"; then
			usage
			shift 1
			return 0
		elif printf "%s\n" "${1}" | grep -qE -- "^(-v)|(--v(e(r(s(i(o(n)?)?)?)?)?)?)"; then
			version
			shift 1
			return 0
		elif printf "%s\n" "${1}" | grep -qE -- "^(-l)|(--l(i(s(t(-(f(i(l(t(e(r(s)?)?)?)?)?)?)?)?)?)?)?)"; then
			listing_filters=true
			shift 1
		elif printf "%s\n" "${1}" | grep -qE -- "^(-a)|(--a(d(d(-(f(i(l(t(e(r)?)?)?)?)?)?)?)?)?)"; then
			adding_filter=true
			shift 1
		elif printf "%s\n" "${1}" | grep -qE -- "^(-r)|(--r(e(m(o(v(e(f(i(l(t(e(r)?)?)?)?)?)?)?)?)?)?)?)"; then
			removing_filter=true
			shift 1
		elif printf "%s\n" "${1}" | grep -qE -- "^(-d)|--d(a(t(a(b(a(s(e)?)?)?)?)?)?)"; then
			case "${1}" in
			*=*)
				leader="${1%%=*}="
				db="${1#"${leader}"}"
				;;
			--database*)
				db="${1#--database}"
				;;
			--databas*)
				db="${1#--databas}"
				;;
			--databa*)
				db="${1#--databa}"
				;;
			--datab*)
				db="${1#--datab}"
				;;
			--data*)
				db="${1#--data}"
				;;
			--dat*)
				db="${1#--dat}"
				;;
			--da*)
				db="${1#--da}"
				;;
			--d*)
				db="${1#--d}"
				;;
			-d*)
				db="${1#-d}"
				;;
			*)
				printf "%s: invalid database format -- '%s\n'" "$(basename "${0}")" "${1}" >&2
				return 2
				;;
			esac
			if [[ -z "${db}" ]]; then
				if [[ -n "${2}" ]]; then
					case "${2}" in
					-*)
						printf "%s: If '--database' is specified, a database path must be provided.\n" "$(basename "${0}")" >&2
						return 2
						;;
					*)
						db="${2}"
						shift 1
						;;
					esac
				else
					printf "%s: If '--database' is specified, a database path must be provided.\n" "$(basename "${0}")" >&2
					return 2
				fi
			fi
			shift 1
			db="${1}"
			shift 1
		elif [[ "${1}" = "--" ]]; then
			shift 1
			break
		elif printf "%s\n" "${1}" | grep -qE -- "^-.*"; then
			cat <<-EOF >&2
				$(basename "$0"): invalid option -- '${1}'
				Try '$(basename "${0}") --help' for more information.
			EOF
			return 2
		else
			command="${*}"
			shift 1
			break
		fi
	done
	db="${db:-"${HOME}/.cmd-log.db"}"
	adding_filter="${adding_filter:-false}"
	removing_filter="${removing_filter:-false}"
	listing_filters="${listing_filters:-false}"
	if "${listing_filters}"; then
		list_filters "${db}"
		return 0	
	elif "${adding_filter}" && "${removing_filter}"; then
		printf "%s: If '--add-filter' is specified '--remove-filter' can't be specified.\n" "$(basename "${0}")" >&2
		return 2
	else
		if [[ -z "${command}" ]]; then
			usage
			return 1
		fi
	fi
	if "${adding_filter}"; then
		add_filter "${db}" "${command}" || return "${?}"
	elif "${removing_filter}"; then
		remove_filter "${db}" "${command}" || return "${?}"
	else
		log_command "${db}" "${command}" || return "${?}"
	fi
}

main "${@}" || exit "${?}"
